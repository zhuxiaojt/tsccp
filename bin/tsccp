#!/usr/bin/env node
import fs from 'fs'
import path from 'path'
import child_process from 'child_process'
import copyfiles from 'copyfiles'
import os from 'os'
import readline from 'readline'

async function main() {
  const cwd = process.cwd()
  const binPath = path.join(cwd, 'node_modules', '.bin');
  const tsconfigPath = path.join(cwd, 'tsconfig.json')

  if (!fs.existsSync(tsconfigPath)) {
    console.error('tsconfig.json not found')
    process.exit(1)
  }

  let tsconfig = null
  try {
    tsconfig = JSON.parse(fs.readFileSync(tsconfigPath, 'utf-8'))
  } catch (error) {
    console.error('tsconfig.json is not valid JSON')
    process.exit(1)
  }

  const tscPath = path.join(binPath, os.platform() === 'win32' ? 'tsc.cmd' : 'tsc')
  if (!fs.existsSync(tscPath)) {
    console.log('Error: TypeScript Compiler not found')
    console.log('please install it:')
    console.log('    npm install -D typescript')
    console.log('or you can install it by pnpm or other package manager:')
    console.log('    pnpm add -D typescript')
    console.log('    yarn add -D typescript')
    console.log('    bun add -D typescript')
    const rl = readline.createInterface({
      input: process.stdin,
      output: process.stdout
    })
    await new Promise((resolve) => {
      rl.question('Do you want to add it to your project by npm now? (Y/N) ', (answer) => {
        if (answer.toLowerCase() === 'y') {
          console.log('Add TypeScript Compiler to your project now...')
          child_process.spawnSync('npm', ['install', '-D', 'typescript'], { stdio: 'inherit', cwd })
        } else {
          process.exit(1)
        }
        rl.close()
        resolve(answer)
      })
    })
  }

  const outDir = tsconfig.compilerOptions.outDir
  const srcDir = tsconfig.compilerOptions.rootDir

  if (!outDir || !srcDir) {
    console.error('outDir or rootDir not found in tsconfig.json')
    process.exit(1)
  }

  await new Promise((resolve, reject) => {
    copyfiles(
      [path.join(srcDir, '**', '*'), outDir],
      { all: true, exclude: ['**/*.ts', '**/*.mts', '**/*.cts'], up: 1 },
      (err) => {
        if (err) {
          console.error('copyfiles failed: ', err)
          process.exit(1)
        } else {
          resolve()
        }
      }
    )
  })

  console.log('copyfiles done')
  
  const result = child_process.spawnSync(
    tscPath,
    process.argv.slice(2),
    { stdio: 'inherit', cwd, shell: true }
  )

  if (result.status !== 0) {
    console.error('tsc failed')
    process.exit(result.status)
  }

  console.log('tsc done')
}
main().catch(err => {
  console.error('Fatal error:', err)
  process.exit(1)
})